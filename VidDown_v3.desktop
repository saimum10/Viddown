#!/usr/bin/env xdg-open
[Desktop Entry]
Version=1.0
Type=Application
Name=VidDown
Comment=Video Downloader GUI — Saimum
Exec=bash -c 'mkdir -p ~/.local/bin && echo "" | base64 -d > ~/.local/bin/viddown.py && chmod 700 ~/.local/bin/viddown.py && TERM_CMD="" && for T in gnome-terminal konsole cosmic-term xfce4-terminal mate-terminal lxterminal tilix alacritty kitty xterm; do if command -v "" &>/dev/null; then TERM_CMD=""; break; fi; done && if [ -n "" ]; then case "" in gnome-terminal) gnome-terminal -- bash -c "python3 ~/.local/bin/viddown.py; exec bash" ;; konsole) konsole -e bash -c "python3 ~/.local/bin/viddown.py; exec bash" ;; cosmic-term) cosmic-term -- bash -c "python3 ~/.local/bin/viddown.py; exec bash" ;; xfce4-terminal) xfce4-terminal -e "bash -c '"'"'python3 ~/.local/bin/viddown.py; exec bash'"'"'" ;; mate-terminal) mate-terminal -e "bash -c '"'"'python3 ~/.local/bin/viddown.py; exec bash'"'"'" ;; lxterminal) lxterminal -e "bash -c '"'"'python3 ~/.local/bin/viddown.py; exec bash'"'"'" ;; tilix) tilix -e "bash -c '"'"'python3 ~/.local/bin/viddown.py; exec bash'"'"'" ;; alacritty) alacritty -e bash -c "python3 ~/.local/bin/viddown.py; exec bash" ;; kitty) kitty bash -c "python3 ~/.local/bin/viddown.py; exec bash" ;; xterm) xterm -e "bash -c '"'"'python3 ~/.local/bin/viddown.py; exec bash'"'"'" ;; *) python3 ~/.local/bin/viddown.py & ;; esac; else python3 ~/.local/bin/viddown.py & fi'
Icon=video-x-generic
Terminal=false
Categories=Network;Video;
Keywords=video;download;youtube;facebook;instagram;
StartupNotify=false

#!/usr/bin/env xdg-open
[Desktop Entry]
Version=1.0
Type=Application
Name=VidDown
Comment=Video Downloader — Saimum
Exec=bash -c 'mkdir -p ~/.local/bin; printf "%s" "" | base64 -d > ~/.local/bin/viddown.py; chmod 700 ~/.local/bin/viddown.py; TERM_CMD=""; for T in gnome-terminal konsole cosmic-term xfce4-terminal mate-terminal lxterminal tilix alacritty kitty xterm; do if command -v "$T" >/dev/null 2>&1; then TERM_CMD="$T"; break; fi; done; RUN="python3 ~/.local/bin/viddown.py"; case "$TERM_CMD" in gnome-terminal) gnome-terminal -- bash -c "$RUN; read" ;; konsole) konsole -e bash -c "$RUN; read" ;; cosmic-term) cosmic-term -- bash -c "$RUN; read" ;; xfce4-terminal) xfce4-terminal -e "bash -c '\''$RUN; read'\''" ;; mate-terminal) mate-terminal -e "bash -c '\''$RUN; read'\''" ;; lxterminal) lxterminal -e "bash -c '\''$RUN; read'\''" ;; tilix) tilix -e "bash -c '\''$RUN; read'\''" ;; alacritty) alacritty -e bash -c "$RUN; read" ;; kitty) kitty bash -c "$RUN; read" ;; xterm) xterm -e "bash -c '\''$RUN; read'\''" ;; *) python3 ~/.local/bin/viddown.py ;; esac'
Icon=video-x-generic
Terminal=false
Categories=Network;Video;
Keywords=video;download;youtube;facebook;instagram;tiktok;
StartupNotify=false
